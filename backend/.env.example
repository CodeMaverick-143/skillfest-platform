# SkillFest Backend Configuration Example

# GitHub OAuth (Main Portal)
GITHUB_CLIENT_ID=your_id
GITHUB_CLIENT_SECRET=your_secret
GITHUB_SYSTEM_TOKEN=your_pat_for_background_sync

# Google OAuth (Admin Portal)
GOOGLE_CLIENT_ID=your_id
GOOGLE_CLIENT_SECRET=your_secret

# Database (NeonDB / Postgres)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Infrastructure
MONGODB_URI=mongodb://localhost:27017
REDIS_URL=localhost:6379

# Platform URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080
ADMIN_URL=http://localhost:4321

# Server Settings
PORT=8080
JWT_SECRET=generate_a_secure_long_string
