# --- SkillFest Production Environment ---

# Database Configuration
DB_NAME=skillfest
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_POSTGRES_PASSWORD

# Security
JWT_SECRET=YOUR_RANDOM_JWT_SECRET
CLOSE_EVENT_PASSWORD=YOUR_ADMIN_CLOSE_PASSWORD

# GitHub OAuth (Participant App)
GITHUB_CLIENT_ID=YOUR_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_CLIENT_SECRET

# GitHub OAuth (Admin Portal)
ADMIN_GITHUB_CLIENT_ID=YOUR_ADMIN_CLIENT_ID
ADMIN_GITHUB_CLIENT_SECRET=YOUR_ADMIN_CLIENT_SECRET

# GitHub System Token (for sync background jobs)
GITHUB_SYSTEM_TOKEN=YOUR_GH_PAT_TOKEN
