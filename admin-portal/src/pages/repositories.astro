---
import Layout from '../layouts/Layout.astro';
import { Plus, Globe } from 'lucide-react';
---

<Layout title="Repositories">
  <div class="space-y-12">
    <!-- ─── Page Header ─── -->
    <div class="flex items-end justify-between border-b border-zinc-100 pb-10">
      <div>
        <h2 class="title-primary !text-4xl text-zinc-950">
          Source <span class="text-indigo-600">Clusters</span>
        </h2>
        <p class="sub-header text-zinc-500 mt-2">Configure and manage GitHub repository nodes for global activity tracking.</p>
      </div>
      
      <button 
        id="addRepoBtn"
        class="bg-zinc-950 text-white px-6 py-3 rounded-xl font-bold text-sm flex items-center gap-2.5 hover:bg-zinc-800 transition-all shadow-lg active:scale-95"
      >
        <Plus size={18} />
        <span>Register Cluster</span>
      </button>
    </div>

    <!-- ─── Repository List ─── -->
    <div class="grid grid-cols-1 gap-6" id="repoList">
      {[1, 2].map(() => (
        <div class="animate-pulse bg-zinc-50 h-32 rounded-2xl border border-zinc-200"></div>
      ))}
    </div>
  </div>

  <!-- ─── Add Repo Modal ─── -->
  <div id="repoModal" class="fixed inset-0 bg-zinc-950/40 backdrop-blur-xl z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-400">
    <div class="bg-white w-full max-w-xl rounded-[24px] p-12 shadow-[0_32px_120px_-12px_rgba(0,0,0,0.35)] border border-zinc-200 relative scale-95 transition-transform duration-400" id="modalContainer">
      <div class="flex items-center gap-4 mb-10">
        <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center border border-indigo-100">
          <Globe size={20} />
        </div>
        <h3 class="text-2xl font-black text-zinc-950 tracking-tight">Add <span class="text-indigo-600">Repository</span></h3>
      </div>
      
      <form id="repoForm" class="space-y-8">
        <div class="space-y-3">
          <label class="label-caps !text-zinc-400">GitHub Repository URL</label>
          <input 
            type="url" 
            name="url"
            placeholder="https://github.com/org/repo"
            required
            class="w-full bg-zinc-50 border-zinc-200 rounded-xl px-5 py-4 font-semibold text-zinc-900 placeholder:text-zinc-300 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition-all shadow-sm"
          />
        </div>
        
        <div class="grid grid-cols-2 gap-6">
          <div class="space-y-3">
            <label class="label-caps !text-zinc-400">Tracking Start</label>
            <input 
              type="date" 
              name="start_date"
              required
              class="w-full bg-zinc-50 border-zinc-200 rounded-xl px-5 py-3.5 font-bold text-zinc-900 focus:border-indigo-400 outline-none transition-all"
            />
          </div>
          <div class="space-y-3">
            <label class="label-caps !text-zinc-400">Tracking End</label>
            <input 
              type="date" 
              name="end_date"
              required
              class="w-full bg-zinc-50 border-zinc-200 rounded-xl px-5 py-3.5 font-bold text-zinc-900 focus:border-indigo-400 outline-none transition-all"
            />
          </div>
        </div>

        <div class="space-y-5">
          <div class="flex items-center gap-3">
            <label class="label-caps !text-zinc-400">Points Allocation</label>
            <div class="h-px flex-1 bg-zinc-100"></div>
          </div>
          <div class="flex items-center justify-between gap-6 bg-zinc-50 p-6 rounded-2xl border border-zinc-200">
            <div>
              <p class="text-[13px] font-bold text-zinc-900">Points Per Merged PR</p>
              <p class="text-[10px] text-zinc-400 font-medium mt-1">Reward for verified code contributions.</p>
            </div>
            <div class="relative">
              <input 
                type="number" 
                name="points_per_pr"
                value="25"
                min="0" max="1000"
                required
                class="w-24 bg-white border border-zinc-200 rounded-xl px-3 py-3 font-bold text-lg tabular-nums text-center focus:border-indigo-400 outline-none transition-all shadow-sm"
              />
            </div>
          </div>
        </div>

        <div class="flex gap-4 pt-4">
          <button 
            type="button"
            id="cancelBtn"
            class="flex-1 px-6 py-4 rounded-xl border border-zinc-200 text-zinc-500 font-bold text-xs uppercase tracking-widest hover:bg-zinc-50 transition-all font-bold"
          >
            Cancel
          </button>
          <button 
            type="submit"
            class="flex-[2] px-6 py-4 rounded-xl bg-zinc-950 text-white font-bold text-xs uppercase tracking-widest hover:bg-zinc-800 shadow-xl transition-all"
          >
            Deploy Tracking
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script is:inline>
  const API_BASE = '/api/admin/repositories';
  const repoList = document.getElementById('repoList');
  const repoModal = document.getElementById('repoModal');
  const modalContainer = document.getElementById('modalContainer');
  const addRepoBtn = document.getElementById('addRepoBtn');
  const cancelBtn = document.getElementById('cancelBtn');
  const repoForm = document.getElementById('repoForm');

  async function loadRepos() {
    try {
      const res = await fetch(API_BASE);
      const repos = await res.json();
      
      if (!repos || repos.length === 0) {
        repoList.innerHTML = '<div class="p-20 text-center bg-zinc-50 rounded-2xl border border-dashed border-zinc-200"><p class="label-caps !text-zinc-400 italic">No repository nodes currently registered.</p></div>';
        return;
      }

      repoList.innerHTML = repos.map(repo => `
        <div class="card p-8 flex items-center justify-between group">
          <div class="flex items-center gap-8">
            <div class="w-14 h-14 bg-zinc-100 text-zinc-400 rounded-xl group-hover:bg-zinc-950 group-hover:text-white transition-all duration-300 flex items-center justify-center border border-zinc-200 transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <h4 class="text-2xl font-bold text-zinc-950 tracking-tight group-hover:text-indigo-600 transition-colors">${repo.owner} / <span class="italic text-indigo-600 group-hover:text-zinc-950">${repo.name}</span></h4>
              <div class="flex items-center gap-4 mt-2">
                 <div class="flex items-center gap-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                    <span class="text-[9px] font-bold uppercase tracking-widest text-zinc-400">${new Date(repo.start_date).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                 </div>
                 <span class="text-zinc-200 text-[10px]">|</span>
                 <span class="text-[9px] font-bold uppercase tracking-widest text-zinc-400">Ends ${new Date(repo.end_date).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>
              <div class="mt-3 flex items-center gap-2">
                <span class="inline-flex items-center gap-2 px-2.5 py-1 rounded-lg bg-indigo-50 border border-indigo-100 text-[9px] font-bold uppercase tracking-wider text-indigo-700">
                  ${repo.points_per_pr ?? 25} pts per PR
                </span>
              </div>
            </div>
          </div>
          
          <div class="flex items-center gap-3 opacity-0 group-hover:opacity-100 transition-all duration-300">
             <a href="/evaluation" onclick="sessionStorage.setItem('rubricRepoId','${repo.id}');" class="p-3 bg-zinc-100 hover:bg-indigo-600 text-zinc-400 hover:text-white rounded-xl transition-all shadow-sm" title="Rubric">
               <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><path d="m9 14 2 2 4-4"/></svg>
             </a>
             <a href="${repo.url}" target="_blank" class="p-3 bg-zinc-100 hover:bg-zinc-950 text-zinc-400 hover:text-white rounded-xl transition-all shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
             </a>
             <button onclick="handleDelete('${repo.id}')" class="p-3 bg-rose-50 hover:bg-rose-600 text-rose-500 hover:text-white rounded-xl transition-all shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
             </button>
           </div>
        </div>
      `).join('');
    } catch (err) {
      repoList.innerHTML = '<div class="p-16 text-center bg-rose-50 rounded-2xl border border-rose-100"><p class="label-caps !text-rose-600">Sync Interrupted: Repository cluster unreachable.</p></div>';
    }
  }

  function showModal() {
    repoModal.classList.remove('hidden');
    setTimeout(() => {
      repoModal.classList.add('opacity-100');
      modalContainer.classList.remove('scale-95');
    }, 10);
  }

  function hideModal() {
    repoModal.classList.remove('opacity-100');
    modalContainer.classList.add('scale-95');
    setTimeout(() => repoModal.classList.add('hidden'), 300);
  }

  window.handleDelete = async (id) => {
    if (!confirm('Drop this repository cluster? Decoupling will cease all activity tracking for this node.')) return;
    try {
      await fetch(`${API_BASE}/${id}`, { method: 'DELETE' });
      loadRepos();
    } catch (e) {
      alert('Mission failed.');
    }
  };

  addRepoBtn.onclick = showModal;
  cancelBtn.onclick = hideModal;
  repoModal.onclick = (e) => { if(e.target === repoModal) hideModal(); };

  repoForm.onsubmit = async (e) => {
    e.preventDefault();
    const formData = new FormData(repoForm);
    const data = {
      url: formData.get('url'),
      start_date: new Date(formData.get('start_date')).toISOString(),
      end_date: new Date(formData.get('end_date')).toISOString(),
      points_per_pr: parseInt(formData.get('points_per_pr')) || 25,
    };
    
    try {
      const url = new URL(data.url);
      const parts = url.pathname.split('/').filter(p => p);
      if (parts.length >= 2) {
        data.owner = parts[0];
        data.name = parts[1];
      }
    } catch (e) {
      alert('Invalid GitHub cluster URL.');
      return;
    }

    try {
      const res = await fetch(API_BASE, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      if (res.ok) {
        hideModal();
        repoForm.reset();
        loadRepos();
      }
    } catch (e) {
      alert('Transmission error.');
    }
  };

  loadRepos();
</script>
