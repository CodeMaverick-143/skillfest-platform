---
const BACKEND_URL = "http://localhost:8080";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin Access | SkillFest</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --background: #ffffff;
        --foreground: #020617;
        --primary: #4f46e5;
      }

      body {
        font-family: "Space Grotesk", sans-serif;
        background: radial-gradient(circle at top right, #f8fafc, #ffffff);
        color: var(--foreground);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
      }

      .glass-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(226, 232, 240, 0.5);
        padding: 4rem;
        border-radius: 2.5rem;
        width: 100%;
        max-width: 440px;
        box-shadow: 
          0 25px 50px -12px rgba(0, 0, 0, 0.05),
          0 0 0 1px rgba(0, 0, 0, 0.01);
        text-align: center;
      }

      .logo {
        font-size: 2.5rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        text-transform: uppercase;
        font-style: italic;
        margin-bottom: 3rem;
      }

      .logo span {
        color: var(--primary);
      }

      .btn-github {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        width: 100%;
        padding: 1.25rem;
        background: #000;
        color: white;
        border-radius: 1.25rem;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.3);
      }

      .btn-github:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.4);
        background: #111;
      }

      .error-msg {
        margin-top: 1.5rem;
        padding: 1rem;
        background: #fef2f2;
        border: 1px solid #fee2e2;
        color: #b91c1c;
        border-radius: 1rem;
        font-size: 0.8rem;
        font-weight: 600;
      }
    </style>
  </head>
  <body class="min-h-screen flex items-center justify-center p-6">
    <div class="glass-card">
      <div class="logo">Skill<span>Fest</span></div>
      
      <h2 class="text-2xl font-black mb-2">Admin Registry</h2>
      <p class="text-slate-500 font-medium mb-12 text-sm leading-relaxed">
        Access restricted to authorized event administrators only. Please authenticate via GitHub.
      </p>

      <a href={`${BACKEND_URL}/api/auth/admin/github/login`} class="btn-github">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        Initialize Admin Session
      </a>

      <div id="error-container" style="display: none;">
        <div class="error-msg" id="error-text"></div>
      </div>

      <p class="mt-12 text-[10px] uppercase font-black tracking-widest text-slate-300">
        System Node: production-v2.0
      </p>
    </div>

    <script>
      const urlParams = new URLSearchParams(window.location.search);
      const error = urlParams.get('error');
      if (error) {
        const container = document.getElementById('error-container');
        const text = document.getElementById('error-text');
        if (container && text) {
          container.style.display = 'block';
          text.textContent = `Access Denied: ${error.replace(/_/g, ' ')}`;
        }
      }
    </script>
  </body>
</html>
