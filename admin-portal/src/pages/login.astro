---
const BACKEND_URL = import.meta.env.PUBLIC_BACKEND_URL || "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Admin Protocol | SkillFest</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --zinc-50: #fafafa;
        --zinc-100: #f4f4f5;
        --zinc-200: #e4e4e7;
        --zinc-400: #a1a1aa;
        --zinc-500: #71717a;
        --zinc-800: #27272a;
        --zinc-900: #18181b;
        --zinc-950: #09090b;
        --indigo-600: #4f46e5;
      }

      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background: var(--zinc-50);
        color: var(--zinc-950);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        overflow: hidden;
      }

      .backdrop {
        position: fixed;
        inset: 0;
        background: radial-gradient(circle at 50% 0%, rgba(79, 70, 229, 0.03) 0%, transparent 70%);
        pointer-events: none;
      }

      .grid-bg {
        position: fixed;
        inset: 0;
        background-image: linear-gradient(var(--zinc-200) 1px, transparent 1px), linear-gradient(90deg, var(--zinc-200) 1px, transparent 1px);
        background-size: 32px 32px;
        mask-image: radial-gradient(circle at 50% 40%, black, transparent 80%);
        opacity: 0.4;
        pointer-events: none;
      }

      .glass-card {
        background: white;
        border: 1px solid var(--zinc-200);
        padding: 4.5rem 3.5rem;
        border-radius: 2.5rem;
        width: 100%;
        max-width: 460px;
        box-shadow: 
          0 20px 40px -10px rgba(0, 0, 0, 0.05),
          0 0 0 1px rgba(0, 0, 0, 0.01);
        text-align: center;
        position: relative;
        z-index: 10;
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .logo {
        font-family: "Space Grotesk", sans-serif;
        font-size: 2.25rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        text-transform: uppercase;
        font-style: italic;
        margin-bottom: 3.5rem;
        color: var(--zinc-950);
      }

      .logo span {
        color: var(--indigo-600);
      }

      .btn-github {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.875rem;
        width: 100%;
        padding: 1.125rem;
        background: var(--zinc-950);
        color: white;
        border-radius: 1.125rem;
        text-decoration: none;
        font-weight: 800;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.3s ease;
        box-shadow: 0 12px 24px -8px rgba(0, 0, 0, 0.3);
      }

      .btn-github:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 32px -12px rgba(0, 0, 0, 0.4);
        background: var(--zinc-800);
      }

      .btn-github svg {
        stroke-width: 2.5;
        width: 18px;
        height: 18px;
      }

      .error-msg {
        margin-top: 1.5rem;
        padding: 1rem;
        background: #fef2f2;
        border: 1px solid #fee2e2;
        color: #b91c1c;
        border-radius: 1rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .system-id {
        margin-top: 3.5rem;
        text-align: center;
      }

      .system-label {
        font-size: 0.625rem;
        text-transform: uppercase;
        font-weight: 800;
        letter-spacing: 0.3em;
        color: var(--zinc-400);
      }
    </style>
  </head>
  <body>
    <div class="backdrop"></div>
    <div class="grid-bg"></div>

    <div class="glass-card">
      <div class="logo">Skill<span>Fest</span></div>
      
      <h2 style="font-size: 1.75rem; font-weight: 800; margin-bottom: 0.75rem; letter-spacing: -0.02em;">Admin Gateway</h2>
      <p style="color: var(--zinc-500); font-weight: 500; font-size: 0.9375rem; margin-bottom: 3rem; line-height: 1.6;">
        Secure orchestration layer for SkillFest events. Authenticate with your GitHub credentials to initialize session.
      </p>

      <a href={`${BACKEND_URL}/api/auth/admin/github/login`} class="btn-github">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        Initialize Session
      </a>

      <div id="error-container" style="display: none;">
        <div class="error-msg" id="error-text"></div>
      </div>

      <div class="system-id">
        <span class="system-label">Protocol node: root-v2.0</span>
      </div>
    </div>

    <script>
      const urlParams = new URLSearchParams(window.location.search);
      const error = urlParams.get('error');
      if (error) {
        const container = document.getElementById('error-container');
        const text = document.getElementById('error-text');
        if (container && text) {
          container.style.display = 'block';
          text.textContent = `Authorization Error: ${error.replace(/_/g, ' ')}`;
        }
      }
    </script>
  </body>
</html>
