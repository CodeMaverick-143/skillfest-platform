---
import Layout from '../layouts/Layout.astro';
import { Users, GitPullRequest, CheckCircle, Activity, Trophy, Calendar, Settings } from 'lucide-react';

// Fetch stats (Server-side for initial render if needed, but here we can just do a placeholder or fetch)
// For simplicity in this demo environment, let's assume we fetch on client or use placeholder data for layout
---

<Layout title="Dashboard">
  <div class="space-y-12">
    <!-- ─── Page Header ─── -->
    <div class="flex items-end justify-between border-b border-zinc-100 pb-10">
      <div>
        <h2 class="title-primary !text-3xl lg:!text-4xl text-zinc-950">
          System <span class="text-indigo-600">Overview</span>
        </h2>
        <p class="sub-header text-zinc-500">Real-time platform metrics and administrative activity logs.</p>
      </div>
      <div class="flex items-center gap-2.5 bg-zinc-50 px-4 py-2 rounded-xl border border-zinc-200 shadow-sm">
        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
        <span class="label-caps !text-emerald-700 tracking-wider text-[10px]">Active Node</span>
      </div>
    </div>

    <!-- ─── Statistics Grid ─── -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" id="statsGrid">
      {[1, 2, 3, 4].map(() => (
        <div class="animate-pulse bg-zinc-50 h-32 rounded-2xl border border-zinc-200"></div>
      ))}
    </div>

    <!-- ─── Content Sections ─── -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Activity Stream -->
      <div class="lg:col-span-8 card bg-white p-10">
        <div class="flex items-center justify-between mb-8">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center border border-indigo-100">
              <Activity size={22} />
            </div>
            <div>
              <h3 class="title-secondary !text-xl text-zinc-900">Recent Activity</h3>
              <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest mt-1">Audit trail monitoring</p>
            </div>
          </div>
          <button class="label-caps !text-indigo-600 hover:text-indigo-700 transition-colors">View All Logs</button>
        </div>
        
        <div class="space-y-3" id="recentActivity">
          {[1, 2, 3].map(() => (
            <div class="animate-pulse h-20 bg-zinc-50 rounded-xl"></div>
          ))}
        </div>
      </div>

      <!-- Control Panel -->
      <div class="lg:col-span-4 space-y-6">
        <div class="card p-10 bg-zinc-900 text-white border-none shadow-xl relative overflow-hidden group">
          <div class="absolute -right-12 -top-12 w-48 h-48 bg-indigo-500/10 rounded-full blur-[60px] group-hover:scale-125 transition-transform duration-1000"></div>
          
          <div class="relative z-10">
            <h3 class="title-secondary !text-white !text-lg mb-8">Quick Actions</h3>
            <div class="space-y-4">
              <button 
                id="syncBtn"
                class="w-full py-4 px-6 rounded-xl bg-white text-zinc-950 font-bold text-sm uppercase tracking-tight hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-between shadow-lg"
              >
                <span>Trigger Global Sync</span>
                <Activity size={18} className="text-indigo-600" />
              </button>
              
              <button class="w-full py-4 px-6 rounded-xl border border-white/10 hover:bg-white/5 font-bold uppercase tracking-tight text-xs transition-all flex items-center justify-between group">
                <span class="text-zinc-400 group-hover:text-white transition-colors">Broadcast Notice</span>
                <div class="w-1.5 h-1.5 rounded-full bg-zinc-700 group-hover:bg-indigo-400"></div>
              </button>

              <div class="mt-8 pt-6 border-t border-white/5">
                <div class="flex items-center justify-between mb-3">
                  <p class="label-caps !text-zinc-500 text-[9px]">Cluster Load</p>
                  <span class="text-[10px] font-bold text-indigo-400 italic">75%</span>
                </div>
                <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div class="w-3/4 h-full bg-indigo-500 rounded-full shadow-[0_0_10px_rgba(99,102,241,0.5)]"></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ─── Event Lifecycle Card ─── -->
        <div id="eventLifecycleCard" class="card p-8 border-none relative overflow-hidden bg-white">
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-6">
              <h4 class="font-bold uppercase tracking-tight text-zinc-900 uppercase">Event Lifecycle</h4>
              <div id="eventStatusBadge" class="flex items-center gap-2 px-2.5 py-1 rounded-lg bg-emerald-50 border border-emerald-100">
                <div id="eventDot" class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                <span id="eventStatusLabel" class="text-[9px] font-bold uppercase tracking-wider text-emerald-700">Active</span>
              </div>
            </div>

            <!-- Current Schedule Display -->
            <div id="eventScheduleBox" class="mt-6 mb-4 p-4 rounded-xl bg-zinc-50 border border-zinc-200 hidden">
              <div class="flex items-center gap-3 mb-2">
                <Calendar size={14} className="text-zinc-400" />
                <span class="text-[9px] font-bold uppercase tracking-widest text-zinc-400">Timeline</span>
              </div>
              <p id="eventScheduleText" class="text-xs font-bold text-zinc-900 italic">Loading schedule...</p>
            </div>

            <p id="eventStatusDesc" class="text-xs font-medium text-zinc-500 leading-relaxed mb-8 px-1">
              Initializing cryptographic signal monitor...
            </p>

            <div class="grid grid-cols-1 gap-2.5">
              <button id="eventActionBtn" class="w-full py-3 px-4 rounded-xl bg-zinc-900 hover:bg-zinc-800 text-white font-bold text-xs uppercase tracking-wider transition-all flex items-center justify-center gap-2.5">
                <Settings size={14} />
                Manage Status
              </button>
              <button id="configTimelineBtn" class="w-full py-3 px-4 rounded-xl bg-zinc-100 hover:bg-zinc-200 text-zinc-900 font-bold text-xs uppercase tracking-wider transition-all flex items-center justify-center gap-2.5">
                <Calendar size={14} />
                Configure Session
              </button>
            </div>
          </div>
        </div>
  </div>
</Layout>

<script is:inline>
  const statsGrid = document.getElementById('statsGrid');
  const recentActivity = document.getElementById('recentActivity');
  const syncBtn = document.getElementById('syncBtn');

  async function loadDashboard() {
    try {
      const statsRes = await fetch('/api/admin/stats');
      const statsData = await statsRes.json();
      
      const challengesRes = await fetch('/api/challenges');
      const challengesData = await challengesRes.json();
      const activeChallenges = Array.isArray(challengesData) ? challengesData.length : 0;

      const stats = [
        { label: 'Platform Users', value: statsData.total_users || 0, color: 'text-indigo-600', bg: 'bg-indigo-50/50', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
        { label: 'PR Pipeline', value: statsData.total_prs || 0, color: 'text-amber-600', bg: 'bg-amber-50/50', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><line x1="6" x2="6" y1="9" y2="21"/></svg>` },
        { label: 'Validated Pulls', value: statsData.merged_prs || 0, color: 'text-emerald-600', bg: 'bg-emerald-50/50', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>` },
        { label: 'Live Clusters', value: activeChallenges, color: 'text-rose-600', bg: 'bg-rose-50/50', icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>` },
      ];

      statsGrid.innerHTML = stats.map(stat => `
        <div class="card p-6 flex flex-col gap-4 group hover:border-zinc-300">
          <div class="w-12 h-12 rounded-xl ${stat.bg} ${stat.color} flex items-center justify-center border border-zinc-100 group-hover:scale-105 transition-transform duration-300 shadow-sm">
            ${stat.icon}
          </div>
          <div>
            <p class="label-caps mb-1 opacity-80">${stat.label}</p>
            <p class="text-3xl font-bold tabular-nums tracking-tight text-zinc-950">${stat.value}</p>
          </div>
        </div>
      `).join('');

      const prsRes = await fetch('/api/admin/prs/merged');
      const prsData = await prsRes.json();
      const recentPRs = Array.isArray(prsData) ? prsData.slice(0, 5) : [];

      if (recentPRs.length === 0) {
        recentActivity.innerHTML = '<div class="p-12 text-center bg-zinc-50 rounded-2xl border border-dashed border-zinc-200"><p class="font-bold uppercase tracking-widest text-zinc-400 text-[10px]">No active audit logs found.</p></div>';
      } else {
        recentActivity.innerHTML = recentPRs.map(pr => `
          <div class="flex items-center gap-5 p-4 rounded-2xl hover:bg-zinc-50 transition-all duration-200 group border border-transparent hover:border-zinc-100">
            <div class="w-10 h-10 rounded-lg bg-zinc-100 flex-shrink-0 flex items-center justify-center font-bold text-zinc-400 group-hover:bg-zinc-950 group-hover:text-white transition-all duration-300 shadow-sm">
              ${pr.user_id ? pr.user_id[0].toUpperCase() : 'U'}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2.5 mb-0.5">
                 <span class="text-indigo-600 font-bold text-[12px] tracking-tight">${pr.user_name || pr.user_id}</span>
                 <span class="badge-status bg-emerald-50 text-emerald-700 border-emerald-100 !px-1.5 !py-0.2 !text-[8px]">Verified</span>
              </div>
              <p class="font-semibold text-zinc-900 truncate text-sm">${pr.title}</p>
            </div>
            <div class="text-right hidden sm:block">
              <p class="label-caps !text-zinc-400 tracking-wider !text-[9px] mb-0.5">Target</p>
              <p class="font-bold text-[10px] text-zinc-600 uppercase italic">${pr.repo_name}</p>
            </div>
          </div>
        `).join('');
      }
    } catch (e) {
      console.error(e);
      statsGrid.innerHTML = '<div class="col-span-full card p-12 text-center text-rose-600 font-bold uppercase text-xl">Operational Error: Could not fetch state.</div>';
    }
  }

  syncBtn.onclick = async () => {
    const originalText = syncBtn.innerHTML;
    syncBtn.disabled = true;
    syncBtn.innerHTML = '<span>Synchronizing...</span><span class="animate-spin text-indigo-400">⌛</span>';
    try {
      await fetch('/api/sync', { method: 'POST' });
      loadDashboard();
    } catch (e) {
      alert('Node communication timeout.');
    } finally {
      syncBtn.disabled = false;
      syncBtn.innerHTML = originalText;
    }
  };

  loadDashboard();
  // ... (rest of the event logic remains the same)

  // ─── Event Lifecycle Control ────────────────────────────────────────────────

  const eventDot = document.getElementById('eventDot');
  const eventStatusLabel = document.getElementById('eventStatusLabel');
  const eventStatusDesc = document.getElementById('eventStatusDesc');
  const eventActionBtn = document.getElementById('eventActionBtn');
  const eventScheduleBox = document.getElementById('eventScheduleBox');
  const eventScheduleText = document.getElementById('eventScheduleText');
  const configTimelineBtn = document.getElementById('configTimelineBtn');
  let isEventActive = true;

  async function loadEventStatus() {
    try {
      const res = await fetch('/api/event/status');
      const data = await res.json();
      isEventActive = data.is_event_active !== false;
      updateEventUI(isEventActive);

      // Update schedule display
      if (data.start_date || data.end_date) {
        eventScheduleBox.classList.remove('hidden');
        const start = data.start_date ? new Date(data.start_date).toLocaleDateString() : 'TBD';
        const end = data.end_date ? new Date(data.end_date).toLocaleDateString() : 'TBD';
        eventScheduleText.textContent = `${start} — ${end}`;
      } else {
        eventScheduleBox.classList.add('hidden');
      }
    } catch (_) {}
  }

  function updateEventUI(active) {
    if (active) {
      eventDot.className = 'w-2 h-2 rounded-full bg-emerald-400 animate-pulse';
      eventStatusLabel.textContent = 'Active';
      eventStatusLabel.className = 'text-[10px] font-black uppercase tracking-widest text-emerald-300';
      eventStatusDesc.textContent = 'The event is currently live. Participants can submit and sync contributions.';
      eventActionBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Close Event
      `;
      eventActionBtn.className = 'w-full py-4 px-6 rounded-2xl bg-rose-500/20 hover:bg-rose-500/40 border border-rose-500/30 text-rose-300 font-black text-xs uppercase tracking-widest transition-all flex items-center justify-center gap-3';
      eventActionBtn.onclick = promptCloseEvent;
    } else {
      eventDot.className = 'w-2 h-2 rounded-full bg-rose-400';
      eventStatusLabel.textContent = 'Closed';
      eventStatusLabel.className = 'text-[10px] font-black uppercase tracking-widest text-rose-300';
      eventStatusDesc.textContent = 'Event is closed. Public access is restricted. Click below to reopen.';
      eventActionBtn.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
        Reopen Event
      `;
      eventActionBtn.className = 'w-full py-4 px-6 rounded-2xl bg-emerald-500/20 hover:bg-emerald-500/40 border border-emerald-500/30 text-emerald-300 font-black text-xs uppercase tracking-widest transition-all flex items-center justify-center gap-3';
      eventActionBtn.onclick = reopenEvent;
    }
  }

  // --- Timeline Configuration Modal ---
  configTimelineBtn.onclick = async () => {
    try {
      const res = await fetch('/api/event/status');
      const data = await res.json();
      
      const overlay = document.createElement('div');
      overlay.style.cssText = 'position:fixed;inset:0;background:rgba(15,12,41,0.9);backdrop-filter:blur(20px);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;';

      const formatForInput = (d) => d ? new Date(d).toISOString().slice(0, 16) : '';

      overlay.innerHTML = `
        <div style="background:white;border-radius:32px;padding:40px;max-width:540px;width:100%;box-shadow:0 32px 80px -8px rgba(0,0,0,0.4);">
          <div class="flex items-center gap-4 mb-8">
            <div class="w-12 h-12 rounded-2xl bg-indigo-50 flex items-center justify-center text-indigo-600">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </div>
            <div>
              <h3 class="text-2xl font-black italic uppercase tracking-tighter text-slate-900 leading-none">Event Configuration</h3>
              <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-2 px-1">Global Session Parameters</p>
            </div>
          </div>

          <div class="space-y-6">
            <div>
              <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 px-1">Event Title</label>
              <input type="text" id="configTitle" value="${data.event_title || ''}" class="w-full p-4 rounded-2xl bg-slate-50 border border-slate-100 font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition-all" placeholder="SkillFest 2026">
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 px-1">Start Date</label>
                <input type="datetime-local" id="configStart" value="${formatForInput(data.start_date)}" class="w-full p-4 rounded-2xl bg-slate-50 border border-slate-100 font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition-all">
              </div>
              <div>
                <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 px-1">End Date</label>
                <input type="datetime-local" id="configEnd" value="${formatForInput(data.end_date)}" class="w-full p-4 rounded-2xl bg-slate-50 border border-slate-100 font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition-all">
              </div>
            </div>

            <div>
              <label class="block text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2 px-1">Sub-headline / Description</label>
              <textarea id="configDesc" rows="3" class="w-full p-4 rounded-2xl bg-slate-50 border border-slate-100 font-bold text-slate-900 focus:outline-none focus:ring-2 focus:ring-indigo-500/20 transition-all resize-none" placeholder="Enter session details...">${data.event_description || ''}</textarea>
            </div>

            <div class="pt-4 flex gap-3">
              <button id="cancelConfig" class="flex-1 py-4 rounded-2xl border border-slate-200 text-slate-400 font-black uppercase tracking-widest text-[10px] hover:bg-slate-50 transition-all">Discard</button>
              <button id="saveConfig" class="flex-1 py-4 rounded-2xl bg-indigo-600 text-white font-black uppercase tracking-widest text-[10px] hover:bg-indigo-700 shadow-lg shadow-indigo-600/20 transition-all">Propagate Changes</button>
            </div>
          </div>
        </div>
      `;

      document.body.appendChild(overlay);

      document.getElementById('cancelConfig').onclick = () => overlay.remove();
      document.getElementById('saveConfig').onclick = async () => {
        const title = document.getElementById('configTitle').value;
        const start = document.getElementById('configStart').value;
        const end = document.getElementById('configEnd').value;
        const desc = document.getElementById('configDesc').value;

        try {
          const updateRes = await fetch('/api/admin/event/config', {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              event_title: title,
              start_date: start ? new Date(start).toISOString() : null,
              end_date: end ? new Date(end).toISOString() : null,
              event_description: desc
            })
          });

          if (updateRes.ok) {
            overlay.remove();
            loadEventStatus();
          } else {
            alert('Failed to update system state.');
          }
        } catch (e) {
          alert('Transmission failure.');
        }
      };
    } catch (e) {
      alert('Could not initialize configuration node.');
    }
  };

  function promptCloseEvent() {
    // Create password modal
    const overlay = document.createElement('div');
    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(15,12,41,0.85);backdrop-filter:blur(20px);z-index:9999;display:flex;align-items:center;justify-content:center;';

    overlay.innerHTML = `
      <div style="background:white;border-radius:32px;padding:48px;max-width:420px;width:90%;box-shadow:0 32px 80px -8px rgba(0,0,0,0.4);">
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
          <div style="width:48px;height:48px;background:#fee2e2;border-radius:16px;display:flex;align-items:center;justify-content:center;">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div>
            <p style="font-weight:900;font-size:18px;color:#0f172a;letter-spacing:-0.02em;">Close Event?</p>
            <p style="font-size:12px;color:#94a3b8;font-weight:600;margin-top:2px;">This will block all public access.</p>
          </div>
        </div>
        <p style="font-size:13px;color:#64748b;font-weight:500;line-height:1.6;margin-bottom:20px;">Enter the admin password to confirm. Once closed, participants cannot submit or sync contributions.</p>
        <input id="closeEventPw" type="password" placeholder="Admin password" autocomplete="current-password"
          style="width:100%;box-sizing:border-box;padding:14px 18px;border:2px solid #e2e8f0;border-radius:16px;font-weight:700;font-size:14px;outline:none;margin-bottom:16px;font-family:inherit;"
          onFocus="this.style.borderColor='#4f46e5'" onBlur="this.style.borderColor='#e2e8f0'"
        />
        <p id="closeEventErr" style="color:#ef4444;font-size:12px;font-weight:700;margin-bottom:12px;display:none;"></p>
        <div style="display:flex;gap:12px;">
          <button id="cancelCloseBtn" style="flex:1;padding:14px;border-radius:14px;border:2px solid #e2e8f0;background:white;font-weight:900;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;cursor:pointer;">Cancel</button>
          <button id="confirmCloseBtn" style="flex:2;padding:14px;border-radius:14px;border:none;background:linear-gradient(135deg,#ef4444,#dc2626);color:white;font-weight:900;font-size:11px;text-transform:uppercase;letter-spacing:0.1em;cursor:pointer;">Confirm Close</button>
        </div>
      </div>
    `;

    document.body.appendChild(overlay);
    document.getElementById('closeEventPw').focus();

    document.getElementById('cancelCloseBtn').onclick = () => overlay.remove();
    overlay.onclick = (e) => { if (e.target === overlay) overlay.remove(); };

    document.getElementById('confirmCloseBtn').onclick = async () => {
      const password = document.getElementById('closeEventPw').value;
      const errEl = document.getElementById('closeEventErr');
      const btn = document.getElementById('confirmCloseBtn');
      if (!password) { errEl.textContent = 'Password is required'; errEl.style.display = 'block'; return; }
      btn.textContent = 'Closing...';
      btn.disabled = true;
      try {
        const res = await fetch('/api/admin/event/close', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ password }),
        });
        const data = await res.json();
        if (!res.ok) {
          errEl.textContent = data.error || 'Failed to close event';
          errEl.style.display = 'block';
          btn.textContent = 'Confirm Close';
          btn.disabled = false;
          return;
        }
        overlay.remove();
        isEventActive = false;
        updateEventUI(false);
        showToast('Event closed. Public access is now restricted.');
      } catch (_) {
        errEl.textContent = 'Network error. Try again.';
        errEl.style.display = 'block';
        btn.textContent = 'Confirm Close';
        btn.disabled = false;
      }
    };

    // Enter key support
    document.getElementById('closeEventPw').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('confirmCloseBtn').click();
    });
  }

  async function reopenEvent() {
    if (!confirm('Reopen the event? Participants will regain full access.')) return;
    try {
      const res = await fetch('/api/admin/event/open', {
        method: 'POST',
        credentials: 'include',
      });
      if (!res.ok) throw new Error();
      isEventActive = true;
      updateEventUI(true);
      showToast('Event is now live. Public access restored.');
    } catch (_) {
      showToast('Failed to reopen event', 'error');
    }
  }

  function showToast(msg, type = 'success') {
    let t = document.getElementById('dashboardToast');
    if (!t) {
      t = document.createElement('div');
      t.id = 'dashboardToast';
      t.style.cssText = 'position:fixed;bottom:40px;left:50%;transform:translateX(-50%);z-index:9999;padding:14px 28px;border-radius:16px;font-weight:900;font-size:13px;transition:all 0.4s;opacity:0;';
      document.body.appendChild(t);
    }
    t.textContent = msg;
    t.style.background = type === 'error' ? '#dc2626' : '#0f172a';
    t.style.color = 'white';
    t.style.opacity = '1';
    clearTimeout(t._timer);
    t._timer = setTimeout(() => { t.style.opacity = '0'; }, 3000);
  }

  loadEventStatus();
</script>
