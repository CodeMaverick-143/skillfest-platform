---
import Layout from '../layouts/Layout.astro';
import { GitPullRequest } from 'lucide-react';
---

<Layout title="PR Verification">
  <div class="space-y-12">
    <!-- ─── Page Header ─── -->
    <div class="flex items-end justify-between border-b border-zinc-100 pb-10">
      <div>
        <h2 class="title-primary !text-4xl text-zinc-950">
          Submission <span class="text-indigo-600">Verification</span>
        </h2>
        <p class="sub-header text-zinc-500 mt-2">Audit and authorize points for merged pull requests across registered clusters.</p>
      </div>
      
      <div class="flex items-center gap-4">
        <button 
          id="authorizeAllBtn"
          onclick="handleAuthorizeAll()"
          class="px-6 py-3 bg-indigo-600 text-white font-bold text-[11px] uppercase tracking-wider rounded-xl hover:bg-indigo-700 transition-all shadow-lg hover:shadow-indigo-200/50 flex items-center gap-2 group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="group-hover:scale-110 transition-transform"><path d="M20 6L9 17l-5-5"/></svg>
          Authorize All
        </button>
        <div class="flex items-center gap-2.5 bg-zinc-50 px-4 py-2 rounded-xl border border-zinc-200 shadow-sm transition-all h-full">
          <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
          <span class="label-caps !text-emerald-700 tracking-wider text-[10px]">Node Sync Active</span>
        </div>
      </div>
    </div>

    <!-- ─── Tab Navigation ─── -->
    <div class="flex items-center gap-1 bg-zinc-100/50 p-1 rounded-2xl w-fit border border-zinc-200/50">
      <button onclick="setTab('pending')" id="tab-pending" class="tab-btn active">Pending Hub</button>
      <button onclick="setTab('approved')" id="tab-approved" class="tab-btn">Authorized</button>
      <button onclick="setTab('rejected')" id="tab-rejected" class="tab-btn">Rejected</button>
    </div>

    <!-- ─── PR List ─── -->
    <div class="grid grid-cols-1 gap-6" id="prList">
      {[1, 2].map(() => (
        <div class="animate-pulse bg-zinc-50 h-32 rounded-2xl border border-zinc-200"></div>
      ))}
    </div>
    
    <!-- ─── Empty State ─── -->
    <div id="emptyState" class="p-40 text-center rounded-[32px] border border-dashed border-zinc-200 bg-zinc-50/50 hidden">
      <div class="flex flex-col items-center gap-6">
        <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center text-zinc-200 shadow-sm border border-zinc-100">
           <GitPullRequest size={32} />
        </div>
        <p class="label-caps !text-zinc-400 tracking-[0.3em] animate-pulse" id="emptyText">No pending verification signals detected.</p>
      </div>
    </div>
  </div>
</Layout>

<style>
  @reference "../styles/globals.css";

  .tab-btn {
    @apply px-6 py-2.5 rounded-xl font-bold text-[10px] uppercase tracking-wider transition-all duration-300;
    @apply text-zinc-400 hover:text-zinc-600;
  }
  .tab-btn.active {
    @apply bg-white text-zinc-950 shadow-sm border border-zinc-200;
  }
</style>

<script is:inline>
  const API_BASE = '/api/admin/prs/merged';
  const prList = document.getElementById('prList');
  const emptyState = document.getElementById('emptyState');
  const authorizeAllBtn = document.getElementById('authorizeAllBtn');
  let currentTab = 'pending';
  let allPRs = [];

  async function setTab(tab) {
    currentTab = tab;
    // Update UI
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    document.getElementById(`tab-${tab}`).classList.add('active');
    
    // Show/Hide Authorize All
    if (tab === 'pending') authorizeAllBtn.classList.remove('hidden');
    else authorizeAllBtn.classList.add('hidden');

    renderPRs();
  }

  async function loadPRs() {
    try {
      const res = await fetch(API_BASE, { credentials: 'include' });
      if (!res.ok) throw new Error('Inaccessible');
      allPRs = await res.json();
      renderPRs();
    } catch (err) {
      console.error(err);
      prList.innerHTML = '<div class="card p-24 bg-rose-50 border-rose-100 text-center flex flex-col items-center gap-5"><p class="label-caps !text-rose-600 animate-pulse tracking-widest">Protocol Error: Submission Cluster Inaccessible</p></div>';
    }
  }

  function renderPRs() {
    const filtered = allPRs.filter(pr => {
      const status = pr.review_status || 'pending';
      if (currentTab === 'pending') return status === 'pending';
      return status === currentTab;
    });

    if (filtered.length === 0) {
      prList.innerHTML = '';
      emptyState.classList.remove('hidden');
      document.getElementById('emptyText').innerText = `No ${currentTab} submissions found.`;
      return;
    }

    emptyState.classList.add('hidden');
    prList.innerHTML = filtered.map(pr => `
      <div class="card p-8 flex items-center justify-between group relative overflow-hidden transition-all duration-300" id="pr-${pr.id}">
        <div class="absolute left-0 top-0 bottom-0 w-1 ${currentTab === 'approved' ? 'bg-emerald-500' : currentTab === 'rejected' ? 'bg-rose-500' : 'bg-zinc-950'} group-hover:w-2 transition-all"></div>
        
        <div class="flex items-center gap-8 pl-4">
          <div class="w-12 h-12 rounded-xl bg-zinc-50 text-zinc-400 flex items-center justify-center border border-zinc-100 group-hover:bg-zinc-950 group-hover:text-white transition-all shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><line x1="6" y1="9" x2="6" y2="21"/></svg>
          </div>
          <div>
            <div class="flex items-center gap-4">
              <h3 class="text-xl font-bold text-zinc-950 tracking-tight group-hover:text-indigo-600 transition-colors">${pr.title} <span class="text-zinc-300 ml-2 font-medium">#${pr.pr_number}</span></h3>
              <span class="badge-status ${pr.review_status === 'approved' ? 'bg-emerald-50 text-emerald-700 border-emerald-100' : pr.review_status === 'rejected' ? 'bg-rose-50 text-rose-700 border-rose-100' : 'bg-amber-50 text-amber-700 border-amber-100'} !px-2 !py-0.5 !text-[8px]">Review: ${pr.review_status || 'pending'}</span>
            </div>
            <div class="flex items-center gap-6 mt-2.5">
              <div class="flex items-center gap-2">
                 <p class="label-caps !text-zinc-400 !text-[8px] tracking-widest">USER</p>
                 <span class="text-[11px] font-bold text-zinc-900">${pr.user_id.split('-')[0]}...</span>
              </div>
              <div class="w-1 h-1 rounded-full bg-zinc-200"></div>
              <div class="flex items-center gap-2">
                 <p class="label-caps !text-zinc-400 !text-[8px] tracking-widest">CLUSTER</p>
                 <span class="text-[11px] font-bold text-zinc-600">${pr.repo_name}</span>
              </div>
              <div class="w-1 h-1 rounded-full bg-zinc-200"></div>
              <div class="flex items-center gap-2.5">
                 <p class="label-caps !text-indigo-400 !text-[8px] tracking-widest">DELTA</p>
                 <span class="text-base font-bold text-indigo-600 tabular-nums tracking-tighter leading-none">+${pr.points} PTS</span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="flex items-center gap-4 opacity-0 group-hover:opacity-100 transition-all px-4">
          <a href="${pr.url}" target="_blank" class="px-4 py-2 bg-zinc-100 hover:bg-zinc-200 text-zinc-600 font-bold text-[9px] uppercase tracking-widest rounded-lg transition-all">Analyze Hub ↗</a>
          ${currentTab === 'pending' ? `
            <div class="flex gap-2">
              <button onclick="handleAction('${pr.id}', 'reject')" class="p-2.5 bg-zinc-100 text-zinc-400 hover:bg-rose-50 hover:text-rose-600 rounded-lg transition-all"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg></button>
              <button onclick="handleAction('${pr.id}', 'authorize')" class="px-6 py-2.5 bg-zinc-950 text-white font-bold text-[10px] uppercase tracking-wider rounded-lg hover:bg-zinc-800 transition-all">Authorize</button>
            </div>
          ` : ''}
        </div>
      </div>
    `).join('');
  }

  async function handleAction(id, action) {
    try {
      const res = await fetch(`/api/admin/prs/${id}/${action}`, { method: 'POST' });
      if (!res.ok) throw new Error('Action failed');
      await loadPRs();
    } catch (err) {
      alert(err.message);
    }
  }

  async function handleAuthorizeAll() {
    if (!confirm("Authorize all currently pending merged PRs? This will award points to all contributors.")) return;
    try {
      authorizeAllBtn.classList.add('opacity-50', 'pointer-events-none');
      authorizeAllBtn.innerText = "Authorizing Cluster...";
      const res = await fetch('/api/admin/prs/authorize-all', { method: 'POST' });
      if (!res.ok) throw new Error('Bulk action failed');
      await loadPRs();
    } catch (err) {
      alert(err.message);
    } finally {
      authorizeAllBtn.classList.remove('opacity-50', 'pointer-events-none');
      authorizeAllBtn.innerText = "Authorize All";
    }
  }

  loadPRs();
</script>
