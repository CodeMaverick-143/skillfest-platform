---
import Layout from '../layouts/Layout.astro';
import { GitPullRequest } from 'lucide-react';
---

<Layout title="PR Verification">
  <div class="space-y-12">
    <!-- ─── Page Header ─── -->
    <div class="flex items-end justify-between border-b border-zinc-100 pb-10">
      <div>
        <h2 class="title-primary !text-4xl text-zinc-950">
          Submission <span class="text-indigo-600">Verification</span>
        </h2>
        <p class="sub-header text-zinc-500 mt-2">Audit and authorize points for merged pull requests across registered clusters.</p>
      </div>
      
      <div class="flex items-center gap-2.5 bg-zinc-50 px-4 py-2 rounded-xl border border-zinc-200 shadow-sm transition-all">
        <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
        <span class="label-caps !text-emerald-700 tracking-wider text-[10px]">Node Sync Active</span>
      </div>
    </div>

    <!-- ─── PR List ─── -->
    <div class="grid grid-cols-1 gap-6" id="prList">
      {[1, 2].map(() => (
        <div class="animate-pulse bg-zinc-50 h-32 rounded-2xl border border-zinc-200"></div>
      ))}
    </div>
    
    <!-- ─── Empty State ─── -->
    <div id="emptyState" class="p-40 text-center rounded-[32px] border border-dashed border-zinc-200 bg-zinc-50/50 hidden">
      <div class="flex flex-col items-center gap-6">
        <div class="w-16 h-16 rounded-2xl bg-white flex items-center justify-center text-zinc-200 shadow-sm border border-zinc-100">
           <GitPullRequest size={32} />
        </div>
        <p class="label-caps !text-zinc-400 tracking-[0.3em] animate-pulse">No pending verification signals detected.</p>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const API_BASE = '/api/admin/prs/merged';
  const prList = document.getElementById('prList');
  const emptyState = document.getElementById('emptyState');

  async function loadPRs() {
    try {
      const res = await fetch(API_BASE);
      const prs = await res.json();
      
      if (!Array.isArray(prs)) {
         throw new Error('Failed to load PRs');
      }

      // Filter for active session (Demo: April 2026)
      const activePRs = prs.filter(pr => {
        if (!pr.merged_at) return false;
        const date = new Date(pr.merged_at);
        return date.getFullYear() === 2026 && date.getMonth() === 3; 
      });

      if (activePRs.length === 0) {
        prList.innerHTML = '';
        emptyState.classList.remove('hidden');
        return;
      }

      emptyState.classList.add('hidden');
      prList.innerHTML = activePRs.map(pr => `
        <div class="card p-8 flex items-center justify-between group relative overflow-hidden transition-all duration-300">
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-zinc-950 group-hover:bg-indigo-600 transition-all duration-300"></div>
          
          <div class="flex items-center gap-8 pl-4">
            <div class="w-12 h-12 rounded-xl bg-zinc-50 text-zinc-400 flex items-center justify-center border border-zinc-100 group-hover:bg-zinc-950 group-hover:text-white transition-all duration-300 shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><line x1="6" y1="9" x2="6" y2="21"/></svg>
            </div>
            <div>
              <div class="flex items-center gap-4">
                <h3 class="text-xl font-bold text-zinc-950 tracking-tight group-hover:text-indigo-600 transition-colors">${pr.title} <span class="text-zinc-300 ml-2 font-medium">#${pr.pr_number}</span></h3>
                <span class="badge-status bg-emerald-50 text-emerald-700 border-emerald-100 !px-2 !py-0.5 !text-[8px]">Status: Merged</span>
              </div>
              <div class="flex items-center gap-6 mt-2.5">
                <div class="flex items-center gap-2">
                   <p class="label-caps !text-zinc-400 !text-[8px] tracking-widest">OWNER</p>
                   <span class="text-[11px] font-bold text-zinc-900">${pr.user_id}</span>
                </div>
                <div class="w-1 h-1 rounded-full bg-zinc-200"></div>
                <div class="flex items-center gap-2">
                   <p class="label-caps !text-zinc-400 !text-[8px] tracking-widest">CLUSTER</p>
                   <span class="text-[11px] font-bold text-zinc-600">${pr.repo_name}</span>
                </div>
                <div class="w-1 h-1 rounded-full bg-zinc-200"></div>
                <div class="flex items-center gap-2.5">
                   <p class="label-caps !text-indigo-400 !text-[8px] tracking-widest">DELTA</p>
                   <span class="text-base font-bold text-indigo-600 tabular-nums tracking-tighter leading-none">+${pr.points} PTS</span>
                </div>
              </div>
            </div>
          </div>
          
          <div class="flex items-center gap-4 opacity-0 group-hover:opacity-100 transition-all duration-300 px-4">
            <a 
              href="${pr.url}" 
              target="_blank"
              class="px-4 py-2 bg-zinc-100 hover:bg-zinc-200 text-zinc-600 font-bold text-[9px] uppercase tracking-widest rounded-lg transition-all"
            >
              Analyze Hub ↗
            </a>
            <div class="flex gap-2">
              <button class="p-2.5 bg-zinc-100 text-zinc-400 hover:bg-rose-50 hover:text-rose-600 rounded-lg transition-all">
                 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              </button>
              <button class="px-6 py-2.5 bg-zinc-950 text-white font-bold text-[10px] uppercase tracking-wider rounded-lg hover:bg-zinc-800 transition-all shadow-sm">
                 Authorize
              </button>
            </div>
          </div>
        </div>
      `).join('');
    } catch (err) {
      console.error(err);
      prList.innerHTML = '<div class="card p-24 bg-rose-50 border-rose-100 text-center flex flex-col items-center gap-5"><p class="label-caps !text-rose-600 animate-pulse tracking-widest">Protocol Error: Submission Cluster Inaccessible</p></div>';
    }
  }

  loadPRs();
</script>
