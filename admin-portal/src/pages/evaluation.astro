---
import Layout from '../layouts/Layout.astro';
import { ClipboardCheck, X, Plus, Trash2, ChevronDown } from 'lucide-react';
---

<Layout title="Evaluations">
  <div class="space-y-12">
    <!-- ─── Page Header ─── -->
    <div class="flex items-end justify-between border-b border-zinc-100 pb-10">
      <div>
        <h2 class="title-primary !text-4xl text-zinc-950">
          Project <span class="text-indigo-600">Evaluations</span>
        </h2>
        <p class="sub-header text-zinc-500 mt-2">Manually score participant contributions against configurable rubric criteria nodes.</p>
      </div>
      <div class="flex items-center gap-4">
        <div class="relative group">
          <input
            type="text"
            id="evalSearch"
            placeholder="Search identifier..."
            class="pl-6 pr-6 py-3.5 rounded-xl bg-white border border-zinc-200 focus:border-indigo-400 focus:ring-4 focus:ring-indigo-50/50 outline-none transition-all w-64 text-sm font-semibold shadow-sm placeholder:text-zinc-300"
          />
        </div>
        <div id="statusFilter" class="flex gap-1.5 p-1 bg-zinc-100 rounded-xl">
          <button data-filter="all" class="filter-btn active">All</button>
          <button data-filter="pending" class="filter-btn">Pending</button>
          <button data-filter="reviewed" class="filter-btn">Reviewed</button>
        </div>
      </div>
    </div>

    <!-- ─── Participant Grid ─── -->
    <div id="evalGrid" class="grid gap-4">
      <!-- Skeleton loaders -->
      {[1,2,3].map(() => (
        <div class="animate-pulse bg-zinc-50 h-24 rounded-2xl border border-zinc-200"></div>
      ))}
    </div>
  </div>

  <!-- ─── Evaluation Panel Modal ─── -->
  <div id="evalModal" class="fixed inset-0 bg-zinc-950/40 backdrop-blur-xl z-[100] flex items-center justify-center hidden opacity-0 transition-opacity duration-400">
    <div class="bg-white w-full max-w-5xl max-h-[90vh] overflow-y-auto rounded-[32px] shadow-[0_32px_120px_-12px_rgba(0,0,0,0.35)] border border-zinc-200 relative scale-95 transition-transform duration-400" id="evalModalContainer">
      <button id="closeEvalModal" class="absolute top-8 right-8 p-3 hover:bg-zinc-100 rounded-xl transition-all group z-20">
        <X size={24} className="text-zinc-400 group-hover:text-zinc-900 group-hover:rotate-90 transition-all duration-300" />
      </button>
      <div class="p-16" id="evalPanelContent">
        <!-- Dynamically rendered -->
      </div>
    </div>
  </div>

  <!-- ─── Rubric Builder Modal ─── -->
  <div id="rubricModal" class="fixed inset-0 bg-zinc-950/40 backdrop-blur-xl z-[110] flex items-center justify-center hidden opacity-0 transition-opacity duration-400">
    <div class="bg-white w-full max-w-3xl max-h-[90vh] overflow-y-auto rounded-[32px] shadow-[0_32px_120px_-12px_rgba(0,0,0,0.35)] border border-zinc-200 relative scale-95 transition-transform duration-400" id="rubricModalContainer">
      <button id="closeRubricModal" class="absolute top-8 right-8 p-3 hover:bg-zinc-100 rounded-xl transition-all group z-20">
        <X size={24} className="text-zinc-400 group-hover:text-zinc-900 group-hover:rotate-90 transition-all duration-300" />
      </button>
      <div class="p-16">
        <div class="flex items-center gap-5 mb-12">
          <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center border border-indigo-100">
            <ClipboardCheck size={24} />
          </div>
          <div>
            <h3 class="text-3xl font-black text-zinc-950 tracking-tight">Rubric <span class="text-indigo-600">Config</span></h3>
            <p class="text-zinc-500 text-sm font-medium mt-1">Define custom scoring categories for this cluster.</p>
          </div>
        </div>

        <div class="space-y-4 mb-8">
          <label class="label-caps !text-zinc-400">Rubric Label</label>
          <input id="rubricName" type="text" placeholder="e.g. Technical Excellence 2026" class="w-full bg-zinc-50 border border-zinc-200 rounded-xl px-6 py-4 font-bold text-zinc-950 placeholder:text-zinc-300 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition-all" />
        </div>

        <!-- Categories List -->
        <div class="mb-6">
          <div class="flex items-center justify-between mb-4">
            <label class="label-caps !text-zinc-400">Criteria Matrix</label>
            <button id="addCategoryBtn" class="flex items-center gap-2 text-indigo-600 font-bold text-[10px] uppercase tracking-widest hover:bg-indigo-50 px-4 py-2 rounded-lg transition-all">
              <Plus size={14} />
              Add Category
            </button>
          </div>

          <div id="categoryList" class="space-y-3">
            <!-- Dynamic category rows -->
          </div>
          <div id="rubricTotal" class="mt-8 p-6 bg-zinc-950 rounded-2xl flex items-center justify-between text-white">
            <span class="label-caps !text-zinc-500 tracking-widest">Aggregate Ceiling</span>
            <div class="flex items-center gap-2">
              <span id="totalMaxScore" class="font-black text-3xl tabular-nums tracking-tighter">0</span>
              <span class="text-zinc-600 font-bold">PTS</span>
            </div>
          </div>
        </div>

        <div class="flex gap-4 mt-12">
          <button id="cancelRubricBtn" class="flex-1 px-6 py-4 rounded-xl border border-zinc-200 text-zinc-500 font-bold text-xs uppercase tracking-widest hover:bg-zinc-50 transition-all font-bold">Cancel</button>
          <button id="saveRubricBtn" class="flex-[2] px-6 py-4 rounded-xl bg-zinc-950 text-white font-bold text-xs uppercase tracking-widest hover:bg-zinc-800 shadow-xl transition-all">Save Rubric</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .filter-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-weight: 800;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #71717a;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn:hover { color: #18181b; }
  .filter-btn.active {
    background: white;
    color: #18181b;
    box-shadow: 0 4px 12px -2px rgba(0,0,0,0.06);
  }
  .score-input {
    width: 4.5rem;
    background: white;
    border: 1px solid #e4e4e7;
    border-radius: 0.75rem;
    padding: 0.5rem;
    font-weight: 800;
    text-align: center;
    font-size: 1.125rem;
    font-variant-numeric: tabular-nums;
    outline: none;
    transition: all 0.15s;
    color: #18181b;
  }
  .score-input:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 4px rgba(99,102,241,0.05);
  }
  .score-input:disabled { opacity: 0.4; cursor: not-allowed; }
  .score-input::-webkit-outer-spin-button,
  .score-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
  .score-input[type=number] { -moz-appearance: textfield; }
  .category-row {
    display: grid;
    grid-template-columns: 1fr 1fr 70px auto;
    gap: 0.75rem;
    align-items: center;
    padding: 1rem;
    background: #fafafa;
    border-radius: 1rem;
    border: 1px solid #f4f4f5;
  }
</style>

<script is:inline>
const API = {
  evaluations: '/api/admin/evaluations',
  users: '/api/admin/users',
  repos: '/api/admin/repositories',
  rubric: (repoId) => repoId ? `/api/admin/repositories/${repoId}/rubric` : '/api/admin/rubric/default',
  submitEval: (id) => `/api/admin/evaluations/${id}/submit`,
  userEvals: (uid) => `/api/admin/evaluations/user/${uid}`,
};

let allUsers = [];
let allEvaluations = [];
let activeFilter = 'all';
let currentUser = null;
let currentRepoId = null;
let currentRubric = null;
let currentEval = null;
let rubricCategories = [];
let currentRubricRepoId = null;

async function init() {
  const [usersRes, evalsRes] = await Promise.all([
    fetch(API.users).then(r => r.json()).catch(() => []),
    fetch(API.evaluations).then(r => r.json()).catch(() => []),
  ]);
  allUsers = usersRes || [];
  allEvaluations = evalsRes || [];
  renderGrid(allUsers);
}

function getEvalStatus(userId) {
  const ev = allEvaluations.find(e => e.user_id === userId);
  if (!ev) return 'pending';
  return ev.reviewed ? 'reviewed' : 'draft';
}

function renderGrid(users) {
  const grid = document.getElementById('evalGrid');
  const searchVal = document.getElementById('evalSearch').value.toLowerCase();
  const filtered = users.filter(u => {
    if (searchVal && !u.username.toLowerCase().includes(searchVal)) return false;
    const status = getEvalStatus(u.id);
    if (activeFilter === 'pending' && status !== 'pending') return false;
    if (activeFilter === 'reviewed' && status !== 'reviewed') return false;
    return true;
  });

  if (!filtered.length) {
    grid.innerHTML = '<div class="p-20 text-center bg-zinc-50 rounded-2xl border border-dashed border-zinc-200"><p class="label-caps !text-zinc-400 italic">No nodes identified for evaluation.</p></div>';
    return;
  }

  grid.innerHTML = filtered.map(user => {
    const status = getEvalStatus(user.id);
    const evalData = allEvaluations.find(e => e.user_id === user.id);
    const statusColor = {
      pending: 'bg-amber-50 text-amber-600 border-amber-100',
      draft: 'bg-indigo-50 text-indigo-700 border-indigo-100',
      reviewed: 'bg-emerald-50 text-emerald-700 border-emerald-100',
    }[status];
    const statusLabel = { pending: 'Unvisited', draft: 'In Revision', reviewed: 'Released' }[status];

    return `
      <div class="card p-6 flex items-center justify-between group hover:bg-zinc-50 transition-all duration-300" onclick="openEvalPanel('${user.id}', '${user.username}')">
        <div class="flex items-center gap-6">
          <div class="w-12 h-12 rounded-xl bg-zinc-100 border border-zinc-200 flex items-center justify-center font-bold text-zinc-400 group-hover:bg-zinc-950 group-hover:text-white transition-all duration-300">
            ${user.username[0].toUpperCase()}
          </div>
          <div>
            <p class="font-bold text-zinc-950 text-[15px] tracking-tight group-hover:text-indigo-600 transition-colors">${user.username}</p>
            <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-wider mt-1 opacity-60">${user.email ? user.email.split('@')[0] : 'external-id'}</p>
          </div>
        </div>
        <div class="flex items-center gap-10">
          <div class="text-right">
            <p class="font-bold text-2xl tabular-nums tracking-tighter text-zinc-950">${(user.points || 0).toLocaleString()}</p>
            <p class="label-caps !text-zinc-400 !text-[8px] mt-0.5 uppercase tracking-widest opacity-60">System Points</p>
          </div>
          ${evalData ? `
            <div class="text-right">
              <p class="font-bold text-2xl tabular-nums tracking-tighter text-indigo-600">+${evalData.total_points}</p>
              <p class="label-caps !text-zinc-400 !text-[8px] mt-0.5 uppercase tracking-widest opacity-60">Merit Points</p>
            </div>
          ` : ''}
          <span class="px-3 py-1 rounded-lg font-bold text-[9px] uppercase tracking-widest border ${statusColor}">${statusLabel}</span>
          <div class="w-8 h-8 rounded-lg bg-zinc-100 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </div>
        </div>
      </div>
    `;
  }).join('');
}

window.openEvalPanel = async function(userId, username) {
  currentUser = { id: userId, username };
  currentRepoId = null;
  currentEval = null;

  showModal('evalModal', 'evalModalContainer');
  document.getElementById('evalPanelContent').innerHTML = loadingSpinner('Syncing evaluation context...');

  try {
    const [repos, userEvals] = await Promise.all([
      fetch(API.repos).then(r => r.json()),
      fetch(API.userEvals(userId)).then(r => r.json()).catch(() => []),
    ]);

    currentEval = userEvals && userEvals[0] ? userEvals[0] : null;
    renderEvalPanel(username, repos || [], currentEval);
  } catch (e) {
    document.getElementById('evalPanelContent').innerHTML = '<p class="text-rose-600 font-bold text-center py-20">Transmission interrupted: Failed to load evaluation context.</p>';
  }
};

function renderEvalPanel(username, repos, existingEval) {
  const isLocked = existingEval?.reviewed;

  document.getElementById('evalPanelContent').innerHTML = `
    <div class="flex items-start justify-between mb-12">
      <div>
        <h3 class="text-5xl font-black tracking-tight text-zinc-950 uppercase leading-none italic">${username}<br/><span class="text-indigo-600 font-black">Audit</span></h3>
        <p class="text-zinc-500 font-medium text-lg mt-4 max-w-lg">Assign merit points for manual contributions and technical impact across registered clusters.</p>
      </div>
      <div class="w-16 h-16 rounded-2xl bg-zinc-50 border border-zinc-200 flex items-center justify-center font-black text-2xl text-zinc-950 shadow-sm">
        ${username[0].toUpperCase()}
      </div>
    </div>

    ${isLocked ? `
      <div class="mb-10 p-6 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl bg-emerald-500 flex items-center justify-center shadow-lg shadow-emerald-100">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <p class="font-bold text-emerald-800 text-sm tracking-tight">Node Evaluation Locked</p>
          <p class="text-emerald-600/70 text-[11px] font-bold uppercase tracking-widest mt-0.5">Authorized by ${existingEval.reviewed_by} · ${existingEval.total_points} PTS Awarded</p>
        </div>
      </div>
    ` : ''}

    <div class="mb-10 space-y-3">
      <label class="label-caps !text-zinc-400">Target Source Node</label>
      <div class="relative">
        <select id="repoSelector" ${isLocked ? 'disabled' : ''} class="w-full bg-zinc-50 border border-zinc-200 rounded-xl px-6 py-4 font-bold text-zinc-900 focus:ring-4 focus:ring-indigo-50 focus:border-indigo-400 outline-none transition-all appearance-none cursor-pointer">
          <option value="">— Global Cluster —</option>
          ${repos.map(r => `<option value="${r.id}" ${existingEval?.repo_id === r.id ? 'selected' : ''}>${r.owner}/${r.name}</option>`).join('')}
        </select>
        <div class="absolute right-6 top-1/2 -translate-y-1/2 pointer-events-none text-zinc-400">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
      </div>
    </div>

    <div id="rubricSection" class="mb-12">
      ${loadingSpinner('Loading rubric criteria...')}
    </div>

    ${!isLocked ? `
    <div class="flex gap-4 pt-10 border-t border-zinc-100">
      <button onclick="saveDraft()" id="saveDraftBtn" class="flex-1 px-6 py-4 rounded-xl border border-zinc-200 text-zinc-500 font-bold text-xs uppercase tracking-widest hover:bg-zinc-50 transition-all">Save Context</button>
      <button onclick="confirmSubmit()" id="submitEvalBtn" class="flex-[2] px-6 py-4 rounded-xl bg-zinc-950 text-white font-bold text-xs uppercase tracking-widest hover:bg-zinc-800 shadow-xl transition-all">
        Deploy Merit Points
      </button>
    </div>
    ` : ''}
  `;

  const repoSelector = document.getElementById('repoSelector');
  repoSelector.addEventListener('change', () => loadRubric(repoSelector.value || null));
  loadRubric(existingEval?.repo_id || null, existingEval);
}

async function loadRubric(repoId, existingEval) {
  currentRepoId = repoId;
  const section = document.getElementById('rubricSection');
  if (!section) return;
  section.innerHTML = loadingSpinner('Syncing rubric matrix...');

  try {
    const res = await fetch(API.rubric(repoId));
    if (!res.ok) {
      section.innerHTML = noRubricPrompt();
      return;
    }
    const data = await res.json();
    currentRubric = data.rubric || data;
    const categories = JSON.parse(currentRubric.categories || '[]');
    const scores = existingEval ? JSON.parse(existingEval.scores || '{}') : {};
    const notes = existingEval ? JSON.parse(existingEval.notes || '{}') : {};
    const isLocked = existingEval?.reviewed;

    renderRubricForm(categories, scores, notes, isLocked);
  } catch (e) {
    section.innerHTML = noRubricPrompt();
  }
}

function renderRubricForm(categories, scores, notes, isLocked) {
  const section = document.getElementById('rubricSection');
  if (!categories.length) {
    section.innerHTML = noRubricPrompt();
    return;
  }

  section.innerHTML = `
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-4">
        <h4 class="label-caps !text-zinc-500 tracking-[0.2em]">Scoring Matrix</h4>
        <div class="px-2.5 py-1 rounded bg-indigo-50 border border-indigo-100 text-[10px] font-bold text-indigo-700 uppercase tracking-widest">${currentRubric?.name || 'Standard'}</div>
      </div>
      <div class="flex items-center gap-6 bg-zinc-950 text-white rounded-2xl px-6 py-3 shadow-lg">
        <span class="label-caps !text-zinc-600 tracking-widest !text-[9px]">Aggregate</span>
        <div class="flex items-center gap-1.5">
          <span id="liveTotal" class="font-black text-2xl tabular-nums leading-none">0</span>
          <span class="text-zinc-600 font-bold text-sm">/ ${categories.reduce((s, c) => s + c.max_score, 0)}</span>
        </div>
      </div>
    </div>

    <div class="space-y-4" id="rubricFormRows">
      ${categories.map(cat => `
        <div class="p-6 border border-zinc-200 rounded-2xl bg-white hover:border-indigo-200 transition-all group">
          <div class="flex items-start justify-between gap-6 mb-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-1.5">
                <span class="font-bold text-zinc-950 text-lg tracking-tight">${cat.label}</span>
                <span class="px-2 py-0.5 rounded-lg bg-zinc-50 border border-zinc-100 text-[9px] font-bold text-zinc-400 uppercase tracking-widest">Cap: ${cat.max_score}</span>
              </div>
              ${cat.description ? `<p class="text-zinc-500 text-sm font-medium leading-relaxed">${cat.description}</p>` : ''}
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <input
                type="number"
                data-key="${cat.key}"
                data-max="${cat.max_score}"
                value="${scores[cat.key] ?? ''}"
                min="0" max="${cat.max_score}"
                placeholder="0"
                ${isLocked ? 'disabled' : ''}
                class="score-input ${isLocked ? 'opacity-40 cursor-not-allowed' : ''}"
                oninput="updateLiveTotal()"
              />
              <span class="text-zinc-400 font-bold text-[10px] uppercase tracking-widest">PTS</span>
            </div>
          </div>
          <textarea
            data-notes-key="${cat.key}"
            placeholder="Audit notes for ${cat.label}..."
            ${isLocked ? 'disabled' : ''}
            class="w-full bg-zinc-50 border border-zinc-200 rounded-xl px-4 py-3 text-sm font-medium placeholder:text-zinc-300 focus:border-indigo-400 focus:ring-4 focus:ring-indigo-50/50 outline-none transition-all resize-none h-16 ${isLocked ? 'opacity-40 cursor-not-allowed' : ''}"
          >${notes[cat.key] || ''}</textarea>
        </div>
      `).join('')}
    </div>
  `;
  updateLiveTotal();
}

function noRubricPrompt() {
  return `
    <div class="p-12 bg-zinc-50 border border-zinc-200 rounded-[32px] text-center">
      <div class="w-12 h-12 bg-white rounded-xl border border-zinc-200 flex items-center justify-center mx-auto mb-6 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#a1a1aa" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      </div>
      <p class="font-bold text-zinc-950 mb-2">No Rubric Matrix Identified</p>
      <p class="text-sm text-zinc-500 font-medium mb-8 max-w-xs mx-auto">Please configure a scoring framework for this cluster in the <strong>Repositories</strong> module.</p>
    </div>
  `;
}

function updateLiveTotal() {
  const inputs = document.querySelectorAll('#rubricFormRows input[data-key]');
  let total = 0;
  inputs.forEach(input => {
    const max = parseInt(input.dataset.max);
    let val = parseInt(input.value) || 0;
    if (val > max) { val = max; input.value = max; }
    if (val < 0) { val = 0; input.value = 0; }
    total += val;
  });
  const el = document.getElementById('liveTotal');
  if (el) el.textContent = total;
}

function collectFormData() {
  const inputs = document.querySelectorAll('#rubricFormRows input[data-key]');
  const notesEls = document.querySelectorAll('#rubricFormRows textarea[data-notes-key]');
  const scores = {};
  const notes = {};
  let total = 0;

  inputs.forEach(input => {
    const key = input.dataset.key;
    const val = Math.min(parseInt(input.value) || 0, parseInt(input.dataset.max));
    scores[key] = val;
    total += val;
  });
  notesEls.forEach(ta => {
    const key = ta.dataset.notesKey;
    notes[key] = ta.value.trim();
  });

  return { scores, notes, total };
}

window.saveDraft = async function() {
  const { scores, notes, total } = collectFormData();
  if (!currentRubric) return alert('No rubric loaded.');

  const btn = document.getElementById('saveDraftBtn');
  btn.textContent = 'Syncing...';
  btn.disabled = true;

  const payload = {
    user_id: currentUser.id,
    repo_id: currentRepoId || undefined,
    rubric_id: currentRubric.id,
    scores: JSON.stringify(scores),
    notes: JSON.stringify(notes),
    total_points: total,
    reviewed: false,
  };

  try {
    const res = await fetch(API.evaluations, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!res.ok) throw new Error();
    currentEval = await res.json();
    showToast('Evaluation state synced');
  } catch (e) {
    showToast('Failed to sync context', 'error');
  } finally {
    btn.textContent = 'Save Context';
    btn.disabled = false;
  }
};

window.confirmSubmit = async function() {
  const { total } = collectFormData();
  if (total === 0) {
    return showToast('Baseline impact required', 'error');
  }

  await window.saveDraft();
  if (!currentEval?.id) return showToast('Context sync required', 'error');

  if (!confirm(`Deploy ${total} merit points to ${currentUser.username}? This authorization is final.`)) return;

  const btn = document.getElementById('submitEvalBtn');
  btn.textContent = 'Authorizing...';
  btn.disabled = true;

  try {
    const res = await fetch(API.submitEval(currentEval.id), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
    });
    if (!res.ok) throw new Error();
    const result = await res.json();
    showToast(`${result.points_awarded} PTS Authorization Successful`);
    hideModal('evalModal', 'evalModalContainer');
    await init();
  } catch (e) {
    showToast('Authorization Interrupted', 'error');
    btn.textContent = 'Deploy Merit Points';
    btn.disabled = false;
  }
};

window.openRubricBuilder = function(repoId) {
  currentRubricRepoId = repoId || null;
  rubricCategories = [];
  showModal('rubricModal', 'rubricModalContainer');
  renderCategoryList();

  fetch(API.rubric(repoId))
    .then(r => r.ok ? r.json() : null)
    .then(data => {
      if (data) {
        const rubric = data.rubric || data;
        document.getElementById('rubricName').value = rubric.name || '';
        rubricCategories = JSON.parse(rubric.categories || '[]');
        renderCategoryList();
      }
    })
    .catch(() => {});
};

function renderCategoryList() {
  const list = document.getElementById('categoryList');
  if (!rubricCategories.length) {
    list.innerHTML = '<div class="py-12 text-center bg-zinc-50 rounded-2xl border border-dashed border-zinc-200"><p class="label-caps !text-zinc-400 italic">No criteria defined yet.</p></div>';
    updateRubricTotal();
    return;
  }

  list.innerHTML = rubricCategories.map((cat, i) => `
    <div class="category-row">
      <input type="text" value="${cat.label}" placeholder="Label"
        class="bg-white border border-zinc-200 rounded-xl px-4 py-3 font-bold text-sm focus:border-indigo-400 outline-none transition-all"
        oninput="updateCategory(${i}, 'label', this.value)" />
      <input type="text" value="${cat.description || ''}" placeholder="Briefing"
        class="bg-white border border-zinc-200 rounded-xl px-4 py-3 text-sm font-medium focus:border-indigo-400 outline-none transition-all placeholder:text-zinc-300"
        oninput="updateCategory(${i}, 'description', this.value)" />
      <input type="number" value="${cat.max_score}" placeholder="Ceil" min="1" max="500"
        class="bg-white border border-zinc-200 rounded-xl px-2 py-3 font-bold text-center text-sm tabular-nums focus:border-indigo-400 outline-none transition-all"
        oninput="updateCategory(${i}, 'max_score', parseInt(this.value)||0); updateRubricTotal()" />
      <button onclick="removeCategory(${i})" class="w-10 h-10 bg-rose-50 hover:bg-rose-600 text-rose-500 hover:text-white rounded-xl flex items-center justify-center transition-all flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
  `).join('');
  updateRubricTotal();
}

window.updateCategory = function(i, field, value) {
  if (rubricCategories[i]) rubricCategories[i][field] = value;
};

window.removeCategory = function(i) {
  rubricCategories.splice(i, 1);
  renderCategoryList();
};

function updateRubricTotal() {
  const total = rubricCategories.reduce((s, c) => s + (parseInt(c.max_score) || 0), 0);
  const el = document.getElementById('totalMaxScore');
  if (el) el.textContent = total;
}

document.getElementById('addCategoryBtn').addEventListener('click', () => {
  const key = `category_${Date.now()}`;
  rubricCategories.push({ key, label: '', description: '', max_score: 10 });
  renderCategoryList();
});

document.getElementById('saveRubricBtn').addEventListener('click', async () => {
  const name = document.getElementById('rubricName').value.trim();
  if (!name) return showToast('Rubric label required', 'error');
  if (!rubricCategories.length) return showToast('baseline criteria required', 'error');

  for (const cat of rubricCategories) {
    if (!cat.label.trim()) return showToast('Matrix labels required', 'error');
    if (!cat.key) cat.key = cat.label.toLowerCase().replace(/\s+/g, '_');
  }

  const payload = {
    name,
    categories: JSON.stringify(rubricCategories),
    repo_id: currentRubricRepoId || undefined,
  };

  const btn = document.getElementById('saveRubricBtn');
  btn.textContent = 'Deploying...';
  btn.disabled = true;

  try {
    const url = currentRubricRepoId ? `/api/admin/repositories/${currentRubricRepoId}/rubric` : '/api/admin/rubric/default';
    const method = currentRubricRepoId ? 'PUT' : 'POST';
    const res = await fetch(url, {
      method,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    if (!res.ok) throw new Error();
    showToast('Matrix Deployment Successful');
    hideModal('rubricModal', 'rubricModalContainer');
  } catch {
    showToast('Deployment Failure', 'error');
  } finally {
    btn.textContent = 'Save Rubric';
    btn.disabled = false;
  }
});

function showModal(id, containerId) {
  const modal = document.getElementById(id);
  const container = document.getElementById(containerId);
  modal.classList.remove('hidden');
  setTimeout(() => {
    modal.classList.add('opacity-100');
    container.classList.remove('scale-95');
  }, 10);
}

function hideModal(id, containerId) {
  const modal = document.getElementById(id);
  const container = document.getElementById(containerId);
  modal.classList.remove('opacity-100');
  container.classList.add('scale-95');
  setTimeout(() => modal.classList.add('hidden'), 300);
}

function loadingSpinner(msg) {
  return `<div class="flex flex-col items-center justify-center py-24 gap-6"><div class="animate-spin rounded-full h-10 w-10 border-t-4 border-indigo-600 border-r-4 border-r-transparent shadow-xl shadow-indigo-100"></div><p class="label-caps !text-zinc-400 animate-pulse tracking-widest">${msg}</p></div>`;
}

let toastTimeout;
function showToast(message, type = 'success') {
  let toast = document.getElementById('globalToast');
  if (!toast) {
    toast = document.createElement('div');
    toast.id = 'globalToast';
    toast.className = 'fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] px-6 py-3.5 rounded-xl font-bold text-xs uppercase tracking-widest shadow-[0_20px_50px_rgba(0,0,0,0.2)] transition-all duration-500 opacity-0 translate-y-4';
    document.body.appendChild(toast);
  }
  toast.textContent = message;
  toast.className = `fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] px-6 py-3.5 rounded-xl font-bold text-xs uppercase tracking-widest shadow-[0_20px_50px_rgba(0,0,0,0.2)] transition-all duration-500 ${type === 'error' ? 'bg-rose-600 text-white' : 'bg-zinc-950 text-white'}`;
  setTimeout(() => toast.classList.remove('opacity-0', 'translate-y-4'), 10);
  clearTimeout(toastTimeout);
  toastTimeout = setTimeout(() => toast.classList.add('opacity-0', 'translate-y-4'), 3000);
}

document.getElementById('closeEvalModal').addEventListener('click', () => hideModal('evalModal', 'evalModalContainer'));
document.getElementById('evalModal').addEventListener('click', e => { if (e.target === document.getElementById('evalModal')) hideModal('evalModal', 'evalModalContainer'); });

document.getElementById('closeRubricModal').addEventListener('click', () => hideModal('rubricModal', 'rubricModalContainer'));
document.getElementById('cancelRubricBtn').addEventListener('click', () => hideModal('rubricModal', 'rubricModalContainer'));
document.getElementById('rubricModal').addEventListener('click', e => { if (e.target === document.getElementById('rubricModal')) hideModal('rubricModal', 'rubricModalContainer'); });

document.getElementById('evalSearch').addEventListener('input', () => renderGrid(allUsers));

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.filter;
    renderGrid(allUsers);
  });
});

init();
</script>
