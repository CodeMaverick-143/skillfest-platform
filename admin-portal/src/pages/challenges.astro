---
import Layout from '../layouts/Layout.astro';
import { Plus, LayoutGrid, Settings2 } from 'lucide-react';
---

<Layout title="Challenges">
  <div class="space-y-12">
    <!-- ─── Page Header ─── -->
    <div class="flex items-end justify-between border-b border-zinc-100 pb-10">
      <div>
        <h2 class="title-primary !text-4xl text-zinc-950">
          Challenge <span class="text-indigo-600">Clusters</span>
        </h2>
        <p class="sub-header text-zinc-500 mt-2">Configure connected repositories and issue metadata for automated tracking nodes.</p>
      </div>
      
      <a href="/repositories" class="px-6 py-3 rounded-xl bg-zinc-950 text-white font-bold text-xs uppercase tracking-widest hover:bg-zinc-800 shadow-xl transition-all flex items-center gap-3">
        <Plus size={18} />
        Register Node
      </a>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Repository Section -->
      <section class="lg:col-span-7 card p-10 bg-white flex flex-col border border-zinc-200 shadow-sm">
        <div class="flex items-center justify-between mb-10">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 bg-zinc-50 text-zinc-400 border border-zinc-100 rounded-xl flex items-center justify-center">
              <LayoutGrid size={20} />
            </div>
            <h3 class="text-xl font-bold text-zinc-950 tracking-tight">Connected Nodes</h3>
          </div>
          <span id="repoCount" class="px-2.5 py-1 rounded-lg bg-indigo-50 text-indigo-700 border border-indigo-100 font-bold text-[9px] uppercase tracking-widest leading-none">SYNCING...</span>
        </div>
        
        <div class="space-y-4 flex-1" id="repoList">
          {[1, 2].map(() => (
            <div class="animate-pulse h-20 bg-zinc-50 rounded-2xl border border-zinc-100"></div>
          ))}
        </div>
      </section>

      <!-- Tags & Config Section -->
      <section class="lg:col-span-5 bg-zinc-950 rounded-[32px] p-10 text-white shadow-2xl relative overflow-hidden group border border-zinc-800">
        <div class="absolute -right-24 -top-24 w-72 h-72 bg-indigo-500/10 rounded-full blur-[100px] group-hover:scale-125 transition-transform duration-1000"></div>
        
        <div class="relative z-10 flex flex-col h-full">
          <div class="flex items-center gap-4 mb-6">
            <Settings2 size={24} className="text-indigo-500" />
            <h3 class="text-xl font-bold text-white tracking-tight">System Parameters</h3>
          </div>
          <p class="text-zinc-500 font-medium text-sm mb-12">Define global tracking mechanics and identifier labels.</p>
          
          <div class="space-y-12">
            <div>
              <p class="label-caps !text-zinc-600 mb-6 tracking-widest !text-[9px]">AUTHORIZED LABELS</p>
              <div class="flex flex-wrap gap-2.5">
                {['skillfest', 'bug', 'enhancement', 'good-first-issue'].map(tag => (
                  <span class="px-3 py-1.5 rounded-lg bg-zinc-900 border border-zinc-800 text-[10px] font-bold tracking-tight text-zinc-300 uppercase">${tag}</span>
                ))}
                <button class="px-3 py-1.5 rounded-lg border border-dashed border-zinc-800 text-[10px] font-bold text-zinc-600 hover:text-white hover:border-zinc-600 transition-all uppercase">+ ADD</button>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-8 pt-10 border-t border-zinc-900">
              <div class="space-y-3">
                <p class="label-caps !text-zinc-600 tracking-widest !text-[9px]">REAL-TIME NODE</p>
                <div class="flex items-center gap-3">
                  <div class="w-10 h-5 rounded-full bg-indigo-600/20 border border-indigo-500/30 relative flex items-center px-1">
                    <div class="w-3 h-3 rounded-full bg-indigo-500 shadow-sm ml-auto"></div>
                  </div>
                  <span class="text-[10px] font-bold text-indigo-500 uppercase tracking-widest animate-pulse leading-none">Active</span>
                </div>
              </div>
              <div class="space-y-2">
                <p class="label-caps !text-zinc-600 tracking-widest !text-[9px]">REWARD SCALAR</p>
                <p class="text-4xl font-black italic tracking-tighter text-zinc-200 leading-none">1.0x</p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Active Issues Grid -->
    <div class="pt-8">
      <div class="flex items-center gap-6 mb-10">
        <h3 class="text-2xl font-bold text-zinc-950 tracking-tight whitespace-nowrap">Verified <span class="text-indigo-600">Activity Stream</span></h3>
        <div class="h-px w-full bg-zinc-100"></div>
        <p id="issuesStatus" class="label-caps !text-zinc-400 tracking-widest animate-pulse whitespace-nowrap !text-[9px]">SYNCING SIGNALS...</p>
      </div>

      <div class="card overflow-hidden border border-zinc-200 shadow-sm bg-white rounded-[32px]">
        <div class="divide-y divide-zinc-50" id="issuesList">
           <div class="p-32 text-center flex flex-col items-center gap-6">
             <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-indigo-600 border-r-2 border-r-transparent"></div>
             <p class="label-caps !text-zinc-400 animate-pulse tracking-widest text-[10px]">Accessing GitHub Service Cluster...</p>
           </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const repoList = document.getElementById('repoList');
  const repoCount = document.getElementById('repoCount');
  const issuesList = document.getElementById('issuesList');
  const issuesStatus = document.getElementById('issuesStatus');

  async function loadRepoData() {
    try {
      const res = await fetch('/api/admin/repositories');
      const repos = await res.json();
      
      repoCount.innerText = `${repos.length} ACTIVE NODES`;
      
      if (repos.length === 0) {
        repoList.innerHTML = '<div class="p-16 text-center bg-zinc-50 rounded-2xl border border-dashed border-zinc-200"><p class="label-caps !text-zinc-400 italic text-[10px]">No active clusters identified.</p></div>';
        return;
      }

      repoList.innerHTML = repos.map(repo => `
        <div class="flex items-center justify-between p-6 rounded-2xl bg-white border border-zinc-200 hover:bg-zinc-50 transition-all duration-300 group">
          <div class="flex items-center gap-5">
            <div class="w-11 h-11 rounded-xl bg-zinc-950 flex items-center justify-center text-white shadow-sm">
               <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            </div>
            <div>
              <p class="font-bold text-zinc-950 text-base tracking-tight leading-tight">${repo.owner} / <span class="text-indigo-600">${repo.name}</span></p>
              <p class="label-caps !text-zinc-400 !text-[8px] mt-1.5 uppercase tracking-widest opacity-60">Node ID: ${repo.id.split('-')[0].toUpperCase()} <span class="mx-1.5">/</span> Hub Source</p>
            </div>
          </div>
          <a href="/repositories" class="w-10 h-10 rounded-lg hover:bg-zinc-200 text-zinc-300 hover:text-zinc-900 transition-all flex items-center justify-center opacity-0 group-hover:opacity-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </a>
        </div>
      `).join('');
    } catch (e) {
      repoCount.innerText = 'SYNC ERROR';
      repoList.innerHTML = '<div class="p-16 text-center bg-rose-50 rounded-2xl border border-rose-100"><p class="label-caps !text-rose-600 animate-pulse text-[10px]">Transmission Error: Sync Failure</p></div>';
    }
  }

  async function loadIssues() {
    try {
      const res = await fetch('/api/challenges');
      const issues = await res.json();
      
      issuesStatus.innerText = `SYNCED: ${issues.length} IDENTIFIED SIGNALS`;
      issuesStatus.classList.remove('animate-pulse');

      if (issues.length === 0) {
        issuesList.innerHTML = '<div class="p-32 text-center flex flex-col items-center gap-4"><p class="label-caps !text-zinc-400 italic text-[10px]">No active signals identified in the cluster.</p></div>';
        return;
      }

      issuesList.innerHTML = issues.map(issue => `
        <div class="px-10 py-8 flex items-center justify-between hover:bg-zinc-50/50 transition-all group">
          <div class="flex gap-8">
            <div class="w-1 h-12 bg-zinc-100 rounded-full group-hover:bg-indigo-600 transition-all duration-300"></div>
            <div>
              <p class="font-bold text-zinc-950 text-xl tracking-tight leading-none group-hover:translate-x-1 transition-transform duration-300">${issue.title}</p>
              <div class="flex items-center gap-5 mt-3.5">
                 <p class="label-caps !text-zinc-400 !text-[9px] tracking-widest uppercase opacity-60">${issue.repo} <span class="mx-2">/</span> SIG-ID: ${issue.id}</p>
                 <div class="flex gap-2.5">
                    <span class="px-2 py-0.5 rounded bg-indigo-50 text-indigo-700 border border-indigo-100 font-bold text-[8px] uppercase tracking-widest">TIER: ${issue.difficulty}</span>
                    ${issue.labels ? issue.labels.slice(0, 1).map(l => `<span class="px-2 py-0.5 rounded bg-zinc-50 text-zinc-500 border border-zinc-100 font-bold text-[8px] uppercase tracking-widest">${l}</span>`).join('') : ''}
                 </div>
              </div>
            </div>
          </div>
          <a href="${issue.url}" target="_blank" class="px-5 py-2.5 bg-zinc-100 hover:bg-zinc-950 hover:text-white rounded-lg text-zinc-600 font-bold text-[10px] uppercase tracking-widest transition-all shadow-sm">
            Analyze Hub ↗
          </a>
        </div>
      `).join('');
    } catch (e) {
      issuesStatus.innerText = 'SIGNAL LOST';
      issuesList.innerHTML = '<div class="p-32 text-center flex flex-col items-center gap-4"><p class="label-caps !text-rose-500 animate-pulse text-[10px]">Security Protocol: Signal Interruption Detected</p></div>';
    }
  }

  loadRepoData();
  loadIssues();
</script>
