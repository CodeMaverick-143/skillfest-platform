---
import Layout from '../layouts/Layout.astro';
import { Terminal } from 'lucide-react';
---

<Layout title="Activity Logs">
  <div class="space-y-12">
    <!-- ─── Page Header ─── -->
    <div class="flex items-end justify-between border-b border-zinc-100 pb-10">
      <div>
        <h2 class="title-primary !text-4xl text-zinc-950">
          Security <span class="text-indigo-600">Audits</span>
        </h2>
        <p class="sub-header text-zinc-500 mt-2">
          Real-time ledger of administrative authorizations and contribution sync signals.
        </p>
      </div>
      
      <div class="flex items-center gap-2.5 bg-zinc-50 px-4 py-2 rounded-xl border border-zinc-200 shadow-sm">
        <div class="w-1.5 h-1.5 rounded-full bg-indigo-600 animate-pulse"></div>
        <span class="label-caps !text-indigo-700 tracking-wider text-[10px]">Active Audit Stream</span>
      </div>
    </div>

    <!-- ─── Terminal Section ─── -->
    <div class="bg-zinc-950 rounded-[32px] overflow-hidden font-mono shadow-2xl relative border border-zinc-800">
      <!-- Terminal Header -->
      <div class="px-8 py-5 bg-zinc-900/50 border-b border-zinc-800 flex items-center justify-between">
        <div class="flex items-center gap-4">
          <div class="w-8 h-8 rounded-lg bg-zinc-800 flex items-center justify-center border border-zinc-700">
            <Terminal size={16} className="text-zinc-400" />
          </div>
          <span class="label-caps !text-zinc-500 tracking-widest text-[9px]">Ledger Protocol v2.0</span>
        </div>
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-zinc-800"></div>
          <div class="w-3 h-3 rounded-full bg-zinc-800"></div>
          <div class="w-3 h-3 rounded-full bg-zinc-800"></div>
        </div>
      </div>

      <!-- Logs Container -->
      <div class="divide-y divide-zinc-900 min-h-[500px]" id="logsContainer">
        <div class="flex flex-col items-center justify-center p-40 gap-6">
          <div class="animate-spin rounded-full h-10 w-10 border-t-2 border-indigo-500 border-r-2 border-r-transparent"></div>
          <p class="label-caps !text-zinc-600 animate-pulse tracking-widest text-[10px]">Syncing Encrypted Ledger...</p>
        </div>
      </div>

      <!-- Terminal Footer -->
      <div class="px-8 py-6 bg-zinc-900/30 border-t border-zinc-900 flex items-center justify-center">
        <button
          id="loadMoreBtn"
          class="px-6 py-2.5 rounded-lg bg-zinc-900 border border-zinc-800 text-zinc-500 font-bold text-[9px] uppercase tracking-widest hover:text-zinc-300 hover:border-zinc-700 transition-all active:scale-95"
        >
          Force Re-Sync Engine
        </button>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
  const logsContainer = document.getElementById("logsContainer");
  const loadMoreBtn = document.getElementById("loadMoreBtn");

  async function loadLogs() {
    try {
      const res = await fetch("/api/admin/logs");
      const logs = await res.json();

      if (!Array.isArray(logs) || logs.length === 0) {
        logsContainer.innerHTML =
          '<div class="p-40 text-center flex flex-col items-center gap-4"><p class="label-caps !text-zinc-600 italic tracking-widest text-[10px]">No audit entries identified.</p></div>';
        return;
      }

      logsContainer.innerHTML = logs
        .map((log) => {
          const date = new Date(log.created_at);
          const time = date.toLocaleTimeString(undefined, { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
          const isAdminAction = log.action.includes("/admin");
          const status = log.status || "200";

          return `
          <div class="px-8 py-4 flex items-center justify-between hover:bg-zinc-900/50 transition-all group border-l-2 border-transparent hover:border-indigo-600">
            <div class="flex items-center gap-8 min-w-0 flex-1">
              <div class="text-zinc-600 text-[10px] w-20 font-bold tabular-nums group-hover:text-zinc-400 transition-colors uppercase">${time}</div>
              <div class="flex items-center gap-3 flex-shrink-0">
                <span class="text-[11px] font-bold text-zinc-500 group-hover:text-zinc-200 transition-colors truncate max-w-[120px] uppercase tracking-tight">${log.user_id}</span>
              </div>
              <div class="text-[12px] truncate ml-4 flex gap-6 items-center flex-1">
                <span class="font-bold tracking-tight ${isAdminAction ? "text-indigo-400" : "text-zinc-400"} group-hover:translate-x-1 transition-transform duration-300">${log.action}</span>
                <span class="text-zinc-700 font-medium group-hover:text-zinc-500 transition-colors truncate max-w-sm text-[11px]">${log.metadata ? JSON.stringify(log.metadata) : ""}</span>
              </div>
            </div>
            <div class="px-3 py-1 rounded-md font-bold text-[9px] uppercase tracking-widest border transition-all ${status.startsWith("2") ? "bg-emerald-500/10 text-emerald-500 border-emerald-500/20" : "bg-rose-500/10 text-rose-500 border-rose-500/20"}">
              ${status}
            </div>
          </div>
        `;
        })
        .join("");
    } catch (e) {
      logsContainer.innerHTML =
        '<div class="p-40 text-center flex flex-col items-center gap-4"><p class="label-caps !text-rose-500 animate-pulse tracking-widest">Protocol Error: Ledger Offline</p></div>';
    }
  }

  loadMoreBtn.onclick = () => {
    loadMoreBtn.innerText = "RE-SYNCING...";
    loadLogs().finally(() => {
      loadMoreBtn.innerText = "FORCE RE-SYNC ENGINE";
    });
  };
  
  loadLogs();
  setInterval(loadLogs, 30000);
</script>
